<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="tapbuy" translate="label" sortOrder="500" class="tapbuy-tab">
            <label>Tapbuy</label>
        </tab>
        <section id="tapbuy" translate="label" type="text" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Checkout Settings</label>
            <tab>tapbuy</tab>
            <resource>Tapbuy_RedirectTracking::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Settings</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Is Tapbuy Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
            <group id="api" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>API Settings</label>
                <field id="api_url" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>API URL for Tapbuy</label>
                    <depends>
                        <field id="tapbuy/general/enabled">1</field>
                    </depends>
                </field>
                <field id="encryption_key" translate="label" type="obscure" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Encryption Key for Tapbuy</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="tapbuy/general/enabled">1</field>
                    </depends>
                </field>
                <field id="locale_format" translate="label comment" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Locale format</label>
                    <comment>Long: en_US, Short: en</comment>
                    <source_model>Tapbuy\RedirectTracking\Model\Config\Source\LocaleFormat</source_model>
                    <depends>
                        <field id="tapbuy/general/enabled">1</field>
                    </depends>
                </field>
            </group>
            <group id="tracking" translate="label" type="text" sortOrder="25" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Tracking Settings</label>
                <field id="order_confirmation_mode" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Order Confirmation Mode</label>
                    <comment>GraphQL Mutation: fired by the frontend after order placement (carries A/B test variation id, field ab_test_id). OrderSaveAfter: fired by the Magento observer on order save (no cookies). Both: fire both.</comment>
                    <source_model>Tapbuy\RedirectTracking\Model\Config\Source\OrderConfirmationMode</source_model>
                    <depends>
                        <field id="tapbuy/general/enabled">1</field>
                    </depends>
                </field>
            </group>
            <group id="logging" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Logging Settings</label>
                <field id="scrubbing_keys_url" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Scrubbing Keys URL</label>
                    <comment>URL of the data-scrubbing keys API endpoint used to anonymize log entries. Leave empty to disable log anonymization.</comment>
                    <depends>
                        <field id="tapbuy/general/enabled">1</field>
                    </depends>
                </field>
            </group>
        </section>
    </system>
</config>