{
    "name": "tapbuy/redirect-tracking",
    "description": "Tapbuy module for redirect and tracking",
    "type": "magento2-module",
    "version": "1.8.3",
    "license": [
        "OSL-3.0"
    ],
    "require": {
        "php": "^8.1",
        "magento/framework": "^103.0",
        "magento/module-checkout": "^100.4",
        "magento/module-sales": "^103.0",
        "magento/module-integration": "^100.4",
        "magento/module-quote": "^101.2",
        "magento/module-graph-ql": "^100.4",
        "phpseclib/phpseclib": "^3.0",
        "tapbuy/data-scrubber": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Tapbuy\\RedirectTracking\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tapbuy\\RedirectTracking\\Test\\": "Test/"
        }
    },
    "scripts": {
        "test": "@php -r \"echo 'Run `make test` to run PHPUnit via Docker (matches CI environment).\\n'; exit(1);\""
    }
}